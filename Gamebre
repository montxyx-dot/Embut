<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Card Pack RNG Game</title>
  <style>
    body { font-family: Arial; text-align: center; background: #111; color: white; }
    button { padding: 10px 20px; font-size: 18px; margin: 20px; }
    .pack { display: flex; justify-content: center; gap: 10px; margin-top: 20px; }
    .card {
      width: 100px; height: 150px;
      background: #333;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      transition: transform 0.3s;
    }
    .rare { background: gold; color: black; }
    .epic { background: purple; }
    .legend { background: red; }
  </style>
</head>
<body>
  <h1>Card Pack RNG</h1>
  <button onclick="openPack()">Buka Pack</button>
  <div class="pack" id="pack"></div>

  <script>
    function getCard() {
      let roll = Math.random() * 100;

      if (roll <= 1) return { name: "LEGEND", class: "legend" }; // 1%
      if (roll <= 3) return { name: "EPIC", class: "epic" };     // 2%
      if (roll <= 10) return { name: "RARE", class: "rare" };    // 7%
      return { name: "COMMON", class: "" };                      // sisanya
    }

    function openPack() {
      const packDiv = document.getElementById("pack");
      packDiv.innerHTML = "";

      let cards = [];

      // 5 kartu per pack
      for (let i = 0; i < 5; i++) {
        cards.push(getCard());
      }

      // Pastikan kartu terakhir lebih bagus (boost chance)
      let lastRoll = Math.random() * 100;
      if (lastRoll <= 10) cards[4] = { name: "LEGEND", class: "legend" };
      else if (lastRoll <= 25) cards[4] = { name: "EPIC", class: "epic" };
      else if (lastRoll <= 60) cards[4] = { name: "RARE", class: "rare" };

      // kecil chance dapet 2 kartu bagus
      if (Math.random() < 0.15) {
        let index = Math.floor(Math.random() * 4);
        cards[index] = { name: "EPIC", class: "epic" };
      }

      cards.forEach(c => {
        let div = document.createElement("div");
        div.className = "card " + c.class;
        div.textContent = c.name;
        packDiv.appendChild(div);
      });
    }
  </script>
</body>
</html>
